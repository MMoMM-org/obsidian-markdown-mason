{
	"name": "obsidian-markdown-mason",
	"version": "0.8.0",
	"description": "Fit pasted or whole-note Markdown into the target note's structure — heading cascade, footnote renumbering, dedup and a curated transform library.",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"build:catalog": "node catalog/build-catalog.mjs",
		"test": "vitest run",
		"test:watch": "vitest",
		"lint": "eslint src/",
		"check:manifest": "node scripts/check-manifest.mjs",
		"compliance": "vitest run test/compliance.test.ts"
	},
	"keywords": [
		"obsidian",
		"obsidian-plugin",
		"markdown",
		"footnotes",
		"paste"
	],
	"author": "Marcus Breiden",
	"license": "MIT",
	"devDependencies": {
		"@codemirror/commands": "^6.10.3",
		"@codemirror/state": "^6.6.0",
		"@codemirror/view": "^6.43.1",
		"@eslint/json": "^2.0.1",
		"@semantic-release/changelog": "^6.0.3",
		"@semantic-release/exec": "^7.0.3",
		"@semantic-release/git": "^10.0.1",
		"@semantic-release/github": "^12.0.8",
		"@types/node": "^22.0.0",
		"conventional-changelog-conventionalcommits": "^9.0.0",
		"esbuild": "0.25.5",
		"eslint": "^9.39.4",
		"eslint-plugin-obsidianmd": "^0.4.1",
		"obsidian": "1.13.1",
		"semantic-release": "^25.0.3",
		"tslib": "2.4.0",
		"typescript": "^5.8.3",
		"typescript-eslint": "^8.61.1",
		"vitest": "^3.2.1"
	}
}
