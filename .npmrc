# Obsidian's API package pins an exact CodeMirror peer (@codemirror/state@6.5.0),
# while this project depends directly on @codemirror/state@^6.6.0 (used in
# src/sources/apply.ts). The mismatch is type-only — Obsidian bundles its own
# CodeMirror at runtime — so we relax strict peer resolution. Without this,
# `npm ci` fails with ERESOLVE on CI (npm 7+ enforces peer deps).
legacy-peer-deps=true
